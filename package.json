{
  "name": "my-electron-app",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "cd renderer && npm run dev",
    "electron": "wait-on http://localhost:5173 && electron .",
    "start": "concurrently \"npm run dev\" \"npm run electron\"",
    "build": "cd renderer && npm run build && cd .. && electron-builder",
    "build:win": "cd renderer && npm run build && cd .. && electron-builder --win",
    "check-tiles": "node scripts/download-tiles.js",
    "extract-tiles": "node scripts/extract_mbtiles.js"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "better-sqlite3": "^11.8.0",
    "concurrently": "^9.2.1", 
    "electron": "^40.5.0",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.myelectronapp.app",
    "productName": "My Electron App",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "renderer/dist/**/*",
      "tiles/**/*"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "express": "^4.21.2"
  }
}
